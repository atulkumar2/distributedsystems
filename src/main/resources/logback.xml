<configuration>

    <!-- ── Console appender: always show logs on terminal ─────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Rolling file appender: persist logs to logs/telemetry.log ─────── -->
    <!-- RollingFileAppender rolls into a new file each day and keeps 30 days  -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/telemetry.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Archive file pattern: one gzipped file per day -->
            <fileNamePattern>logs/telemetry.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <!-- Keep 30 days of history; delete anything older automatically -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Reduce noise from Kafka internal client logs ──────────────────── -->
    <!-- Kafka client logs at DEBUG/TRACE level heavily during normal operation -->
    <logger name="org.apache.kafka" level="WARN"/>

    <!-- ── Root logger: INFO and above go to both console and file ──────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
